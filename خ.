نجاح ✅', 'success');
                        loadAdsForAdmin();
                    }
                } catch (error) {
                    showMessage('حدث خطأ في حذف الإعلان', 'error');
                }
            }
        }

        async function loadAdsForAdmin() {
            try {
                const response = await fetch('/api/ads');
                const ads = await response.json();
                
                const container = document.getElementById('adminAdsList');
                
                if (ads.length === 0) {
                    container.innerHTML = '<p style="text-align:center;color:#999;">لا توجد إعلانات حالياً</p>';
                    return;
                }
                
                container.innerHTML = ads.map(ad => `
                    <div class="ad-item">
                        <div class="ad-info">
                            <h3>${escapeHtml(ad.title)}</h3>
                            <p>${escapeHtml(ad.description.substring(0, 100))}...</p>
                            <small>💰 ${ad.price} | 📅 ${new Date(ad.createdAt).toLocaleDateString('ar-EG')}</small>
                        </div>
                        <button onclick="deleteAd(${ad.id})" class="delete-btn">🗑️ حذف</button>
                    </div>
                `).join('');
            } catch (error) {
                console.error('خطأ:', error);
            }
        }

        function clearForm() {
            document.getElementById('adTitle').value = '';
            document.getElementById('adDescription').value = '';
            document.getElementById('adPrice').value = '';
            document.getElementById('adImage').value = '';
            document.getElementById('adLink').value = '';
        }

        function showMessage(msg, type) {
            const messageDiv = document.getElementById('formMessage');
            messageDiv.innerHTML = `<div class="${type}">${msg}</div>`;
            setTimeout(() => {
                messageDiv.innerHTML = '';
            }, 3000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        if (localStorage.getItem('adminLoggedIn') === 'true') {
            showDashboard();
            loadAdsForAdmin();
        }
    </script>
</body>
</html>
